{
  "name": "research-issue-board",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "tsc --noEmit && vite build --mode github-pages",
    "check:deployment": "node scripts/check-deployment-readiness.mjs",
    "check:env": "node scripts/check-company-env.mjs",
    "check:env:example": "node scripts/check-company-env.mjs .env.example --allow-placeholders",
    "check:shell": "sh -n scripts/company-run.sh",
    "preview": "vite preview",
    "test": "vitest run",
    "test:backend": ".venv/bin/python -m unittest backend.tests.test_security backend.tests.test_api",
    "test:e2e": "node scripts/run-playwright-with-ports.mjs local",
    "test:e2e:headed": "node scripts/run-playwright-with-ports.mjs local --headed",
    "test:e2e:pages": "node scripts/run-playwright-with-ports.mjs pages",
    "test:e2e:pages:live": "playwright test --config playwright.live-pages.config.ts",
    "test:e2e:pages:live:current": "pnpm build:pages && LIVE_PAGES_REQUIRE_CURRENT_BUILD=1 playwright test --config playwright.live-pages.config.ts",
    "test:e2e:server": "node scripts/run-playwright-with-ports.mjs server",
    "test:watch": "vitest",
    "verify:static": "pnpm check:shell && pnpm check:deployment && pnpm check:env:example && pnpm test:backend && pnpm test && pnpm build",
    "verify:e2e": "pnpm test:e2e && pnpm test:e2e:pages && pnpm test:e2e:pages:live && pnpm test:e2e:server",
    "verify:all": "pnpm verify:static && pnpm verify:e2e"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/rapier": "^2.2.0",
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "meshline": "^3.3.1",
    "react": "latest",
    "react-dom": "latest",
    "three": "^0.184.0",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "latest",
    "vitest": "latest"
  }
}
